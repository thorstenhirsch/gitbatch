Output .github/assets/gitbatch-demo.gif

Set Shell "bash"
Set FontFamily "Menlo"
Set FontSize 22
Set Width 1400
Set Height 900
Set Theme "Builtin Dark"
Set Framerate 30
Set Padding 24
Set TypingSpeed 70ms

Type "/tmp/gitbatch-demo-bin -d /tmp/gitbatch-demo/work"
Enter

Sleep 5s
Type "?"
Sleep 2s
Type "?"
Sleep 1s
Down 2
Sleep 1s
Type "S"
Sleep 3s
Escape
Sleep 1s
Up
Sleep 1s
Type "b"
Sleep 2s
Escape
Sleep 1s
Type "f"
Sleep 4s
Type "p"
Sleep 5s
Down
Sleep 1s
Type "p"
Sleep 4s
Type "q"
Sleep 2s
